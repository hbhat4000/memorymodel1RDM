  ==> Input File <==

--------------------------------------------------------------------------
molecule hehp {
1 1
H  0.       0.      -0.386
He 0.       0.       0.386
}

set {
    reference rhf
    basis sto-3g
    num_roots 4
    ms0 false
    print 2
    dipmom true
    opdm true
    tdm true
    mo_write true
}

energy('fci')

thisenergy, ciwfn = prop('fci', properties=['DIPOLE', 'TRANSITION_DIPOLE'], return_wfn=True)

for i in range(4):
    for j in range(i+1):
        ciop_dm = ciwfn.get_opdm(i,j,'SUM',True)
        ciop_dm.print_out()

mints = MintsHelper(ciwfn.basisset())

AOdip = mints.ao_dipole()
AOdip[0].print_out()
AOdip[1].print_out()
AOdip[2].print_out()

ciwfn.Ca().print_out()               # Print orbital information




